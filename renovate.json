{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 10am on monday"
  ],
  "assignees": [
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s-the-easy-way/k8s-manifests/.*\\.yaml$/",
      "/tests/assets/k8s/.*\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/argocd/.+\\.yaml$/",
      "/argocd/projects/.+\\.yaml$/",
      "/k8s-the-easy-way/argocd/.+\\.yaml$/"
    ]
  },
  "gomod": {
    "managerFilePatterns": [
      "/tests/.*go\\.mod$/",
      "/(^|/)go\\.mod$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)values\\.yaml$/",
      "/k8s-the-easy-way/helm-values/*\\.yaml/",
      "/kind/kind-values.*\\.yaml$/"
    ]
  }
}
